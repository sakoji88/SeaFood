@model RegisterViewModel
@{ ViewData["Title"] = "Регистрация"; }
<h2>Регистрация</h2>
<form method="post" class="card p-4 shadow-sm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="FullName" class="form-label">ФИО</label><input asp-for="FullName" maxlength="150" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Email" class="form-label">Email</label><input asp-for="Email" type="email" maxlength="150" class="form-control" /><span asp-validation-for="Email" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Phone" class="form-label">Телефон</label><input asp-for="Phone" maxlength="30" class="form-control" /><span asp-validation-for="Phone" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Password" class="form-label">Пароль</label><input asp-for="Password" type="password" maxlength="100" class="form-control" /><span asp-validation-for="Password" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="ConfirmPassword" class="form-label">Подтверждение пароля</label><input asp-for="ConfirmPassword" type="password" maxlength="100" class="form-control" /><span asp-validation-for="ConfirmPassword" class="text-danger"></span></div>
    <button class="btn btn-accent">Зарегистрироваться</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
