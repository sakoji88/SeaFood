@model CategoryCreateEditViewModel
@{ ViewData["Title"] = "Добавить категорию"; }
<h2>Добавить категорию</h2>
<form method="post" class="card p-3">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-2"><label asp-for="Name" class="form-label">Название</label><input asp-for="Name" maxlength="100" class="form-control"/><span asp-validation-for="Name" class="text-danger"></span></div><div class="mb-2"><label asp-for="Description" class="form-label">Описание</label><textarea asp-for="Description" maxlength="500" class="form-control"></textarea></div><button class="btn btn-accent">Сохранить</button></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
