@model IEnumerable<Product>
@{
    ViewData["Title"] = "Главная";
}

<section class="landing-wrap d-flex align-items-center justify-content-center">
    <div class="landing-card text-center">
        <h1 class="display-3 fw-bold mb-3">Kacer Fish</h1>
        <p class="lead mb-2">Современный магазин свежих и качественных морепродуктов.</p>
        <p class="text-light-emphasis mb-4">Удобный каталог, актуальные цены и только лучшие позиции для вашего стола.</p>
        <a class="btn btn-lg btn-accent px-5" asp-controller="Products" asp-action="Index">Перейти в каталог</a>
    </div>
</section>
