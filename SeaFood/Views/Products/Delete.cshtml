@model Product
@{ ViewData["Title"] = "Удалить товар"; }
<h2>Удалить товар</h2>
<p>Вы уверены, что хотите удалить <strong>@Model.Name</strong>?</p>
<form method="post">@Html.AntiForgeryToken()<button class="btn btn-danger">Удалить</button><a class="btn btn-secondary" asp-action="Index">Отмена</a></form>
