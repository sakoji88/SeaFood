@model IEnumerable<Product>
@{
    ViewData["Title"] = "Каталог";
    var filter = (ProductFilterViewModel)ViewBag.Filter;
    var categories = (IEnumerable<Category>)ViewBag.Categories;
    var suppliers = (IEnumerable<Supplier>)ViewBag.Suppliers;
}

<h2 class="mb-3">Каталог товаров</h2>
<form method="get" class="card p-3 mb-4">
    <div class="row g-2">
        <div class="col-md-3"><input name="SearchTerm" value="@filter.SearchTerm" maxlength="200" class="form-control" placeholder="Поиск по названию" /></div>
        <div class="col-md-2"><select name="CategoryId" class="form-select"><option value="">Все категории</option>@foreach (var c in categories){<option selected="@(filter.CategoryId == c.Id)" value="@c.Id">@c.Name</option>}</select></div>
        <div class="col-md-2"><select name="SupplierId" class="form-select"><option value="">Все поставщики</option>@foreach (var s in suppliers){<option selected="@(filter.SupplierId == s.Id)" value="@s.Id">@s.Name</option>}</select></div>
        <div class="col-md-1"><input type="number" step="0.01" min="0" name="MinPrice" value="@filter.MinPrice" class="form-control" placeholder="От" /></div>
        <div class="col-md-1"><input type="number" step="0.01" min="0" name="MaxPrice" value="@filter.MaxPrice" class="form-control" placeholder="До" /></div>
        <div class="col-md-2"><select name="SortBy" class="form-select">
            <option value="date_desc">Сначала новые</option><option value="name_asc">Название А-Я</option><option value="name_desc">Название Я-А</option><option value="price_asc">Цена по возрастанию</option><option value="price_desc">Цена по убыванию</option>
        </select></div>
        <div class="col-md-1 d-flex align-items-center"><input class="form-check-input me-1" type="checkbox" name="InStockOnly" value="true" checked="@(filter.InStockOnly == true)" /><label>В наличии</label></div>
    </div>
    <button class="btn btn-accent mt-3">Применить</button>
</form>

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-outline-primary mb-3" asp-action="Create">Добавить товар</a>
}

<div class="row g-4">
@foreach (var item in Model)
{
    var image = item.ProductImages.FirstOrDefault(x => x.IsMain)?.ImageUrl ?? "https://placehold.co/600x400/0f2742/ffffff?text=Kacer+Fish";
    <div class="col-md-3">
        <div class="card product-card h-100">
            <img src="@image" class="card-img-top" alt="@item.Name" />
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">@item.Name</h5>
                <p class="small text-muted">@item.Category?.Name • @item.Supplier?.Name</p>
                <p class="fw-bold">@item.Price.ToString("0.00") ₽ / кг</p>
                <a class="btn btn-sm btn-accent mt-auto" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
            </div>
        </div>
    </div>
}
</div>
@if (!Model.Any())
{
    <div class="alert alert-info mt-4">Ничего не найдено</div>
}
