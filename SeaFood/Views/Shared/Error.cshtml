@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="text-center py-5">
    <h1 class="text-danger">Произошла ошибка</h1>
    <p>Мы уже работаем над исправлением. Попробуйте позже.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-accent">Вернуться на главную</a>
</div>
