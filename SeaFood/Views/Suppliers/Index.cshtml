@model IEnumerable<Supplier>
@{ ViewData["Title"] = "Поставщики"; }
<h2>Поставщики</h2>
<a asp-action="Create" class="btn btn-accent mb-3">Добавить поставщика</a>
<table class="table table-striped"><thead><tr><th>Название</th><th>Страна</th><th>Телефон</th><th></th></tr></thead><tbody>
@foreach(var s in Model){<tr><td>@s.Name</td><td>@s.Country</td><td>@s.ContactPhone</td><td><a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Изменить</a> <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Удалить</a></td></tr>}
</tbody></table>
